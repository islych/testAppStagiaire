@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head><meta charset="utf-8" /><title>Inscription</title></head>
<body>
    <h2>Inscription Stagiaire</h2>
    @if (ViewBag.Erreur != null) { <p style="color:red">@ViewBag.Erreur</p> }
    <form method="post">
        <p><label>Nom<br /><input type="text" name="nom" required /></label></p>
        <p><label>Prénom<br /><input type="text" name="prenom" required /></label></p>
        <p><label>Email<br /><input type="email" name="email" required /></label></p>
        <p><label>Mot de passe<br /><input type="password" name="motDePasse" required /></label></p>
        <button type="submit">S'inscrire</button>
    </form>
    <p><a href="/Account/Login">Déjà un compte ?</a></p>
</body>
</html>
