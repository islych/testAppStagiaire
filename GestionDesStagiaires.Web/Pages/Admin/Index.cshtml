@page
@model GestionDesStagiaires.Web.Pages.Admin.IndexModel

@{
    ViewData["Title"] = "Administration";
}

<div class="container-fluid mt-4">
    <h1 class="mb-4">
        <i class="bi bi-shield-lock"></i> Gestion des Utilisateurs
    </h1>

    <!-- Messages d'alerte -->
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle"></i> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <!-- Formulaire de création -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-person-plus"></i> Créer un nouvel utilisateur
                    </h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="Create">
                        <div class="mb-3">
                            <label for="newUser.Nom" class="form-label">Nom</label>
                            <input type="text" class="form-control" id="newUser.Nom" asp-for="NewUser.Nom" required>
                            <span asp-validation-for="NewUser.Nom" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label for="newUser.Prenom" class="form-label">Prénom</label>
                            <input type="text" class="form-control" id="newUser.Prenom" asp-for="NewUser.Prenom" required>
                            <span asp-validation-for="NewUser.Prenom" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label for="newUser.Email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="newUser.Email" asp-for="NewUser.Email" required>
                            <span asp-validation-for="NewUser.Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label for="newUser.RoleId" class="form-label">Rôle</label>
                            <select class="form-select" id="newUser.RoleId" asp-for="NewUser.RoleId" required>
                                <option value="">-- Sélectionner un rôle --</option>
                                @foreach (var role in Model.Roles.Where(r => r.Nom != "Stagiaire"))
                                {
                                    <option value="@role.Id">@role.Nom</option>
                                }
                            </select>
                            <span asp-validation-for="NewUser.RoleId" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-plus-circle"></i> Créer l'utilisateur
                        </button>
                    </form>

                    <div class="mt-3 p-3 bg-light rounded small">
                        <i class="bi bi-info-circle text-info"></i>
                        <strong>Note :</strong> Un mot de passe temporaire sera généré automatiquement.
                    </div>
                </div>
            </div>
        </div>

        <!-- Liste des utilisateurs -->
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-people"></i> Liste des utilisateurs
                    </h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.Users.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Nom</th>
                                        <th>Prénom</th>
                                        <th>Email</th>
                                        <th>Rôle</th>
                                        <th>Statut</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in Model.Users.OrderByDescending(u => u.DateCreation))
                                    {
                                        <tr>
                                            <td>@user.Nom</td>
                                            <td>@user.Prenom</td>
                                            <td>@user.Email</td>
                                            <td>
                                                <span class="badge bg-info">@user.Role</span>
                                            </td>
                                            <td>
                                                @if (user.Statut)
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-check-circle"></i> Actif
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">
                                                        <i class="bi bi-x-circle"></i> Inactif
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <form method="post" asp-page-handler="ToggleStatus" style="display: inline;">
                                                        <input type="hidden" name="userId" value="@user.Id">
                                                        <button type="submit" class="btn btn-warning btn-sm" title="Basculer le statut">
                                                            <i class="bi bi-arrow-repeat"></i>
                                                        </button>
                                                    </form>
                                                    <form method="post" asp-page-handler="Delete" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');">
                                                        <input type="hidden" name="userId" value="@user.Id">
                                                        <button type="submit" class="btn btn-danger btn-sm" title="Supprimer">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">
                            <i class="bi bi-inbox display-4"></i>
                            <p class="mt-2">Aucun utilisateur trouvé</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
