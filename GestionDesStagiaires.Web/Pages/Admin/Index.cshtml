@page
@model GestionDesStagiaires.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Administration";
    var departements = new[] {
        new { Id = 1,  Nom = "Ressources Humaines" },
        new { Id = 2,  Nom = "Systèmes d'Information" },
        new { Id = 3,  Nom = "Développement Informatique" },
        new { Id = 4,  Nom = "Réseaux et Télécommunications" },
        new { Id = 5,  Nom = "Électrotechnique" },
        new { Id = 6,  Nom = "Électromécanique" },
        new { Id = 7,  Nom = "Maintenance Industrielle" },
        new { Id = 8,  Nom = "Production" },
        new { Id = 9,  Nom = "Distribution" },
        new { Id = 10, Nom = "Transport d'Électricité" },
        new { Id = 11, Nom = "Énergies Renouvelables" },
        new { Id = 12, Nom = "Génie Civil" },
        new { Id = 13, Nom = "Achats et Logistique" },
        new { Id = 14, Nom = "Finance et Comptabilité" },
        new { Id = 15, Nom = "Audit et Contrôle de Gestion" },
        new { Id = 16, Nom = "Juridique" },
        new { Id = 17, Nom = "Communication" },
        new { Id = 18, Nom = "Qualité, Sécurité et Environnement (QSE)" },
    };
}

<div class="container-fluid py-4" style="max-width:1200px">
    <h2 class="mb-4"><i class="bi bi-shield-lock text-primary"></i> Gestion des utilisateurs</h2>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage) || TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-circle"></i> @(Model.ErrorMessage ?? TempData["ErrorMessage"]?.ToString())
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        <!-- Formulaire création -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="bi bi-person-plus"></i> Nouvel utilisateur</h6>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="Create">
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Nom</label>
                            <input type="text" class="form-control form-control-sm" asp-for="NewUser.Nom" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Prénom</label>
                            <input type="text" class="form-control form-control-sm" asp-for="NewUser.Prenom" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Email</label>
                            <input type="email" class="form-control form-control-sm" asp-for="NewUser.Email" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Rôle</label>
                            <select class="form-select form-select-sm" asp-for="NewUser.RoleId" id="roleSelect"
                                    onchange="toggleDeptField()" required>
                                <option value="">-- Sélectionner --</option>
                                @foreach (var role in Model.Roles.Where(r => r.Nom != "Stagiaire"))
                                {
                                    <option value="@role.Id">@role.Nom</option>
                                }
                            </select>
                        </div>
                        <!-- Département — visible uniquement pour Encadrant -->
                        <div class="mb-3 d-none" id="deptField">
                            <label class="form-label small fw-semibold">
                                Département <span class="text-danger">*</span>
                            </label>
                            <select class="form-select form-select-sm" asp-for="NewUser.DepartementId" id="deptSelect">
                                <option value="">-- Sélectionner --</option>
                                @foreach (var dept in departements)
                                {
                                    <option value="@dept.Id">@dept.Nom</option>
                                }
                            </select>
                            <small class="text-muted">L'encadrant ne verra que les candidatures de ce département.</small>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm w-100">
                            <i class="bi bi-plus-circle"></i> Créer
                        </button>
                    </form>
                    <div class="alert alert-info alert-sm mt-3 py-2 small mb-0">
                        <i class="bi bi-info-circle"></i> Un mot de passe temporaire sera généré.
                    </div>
                </div>
            </div>
        </div>

        <!-- Liste utilisateurs -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-people text-secondary"></i> Utilisateurs (@Model.Users.Count)</h6>
                    <input type="text" class="form-control form-control-sm w-auto" id="searchUser"
                           placeholder="Rechercher…" onkeyup="filtrerUsers()">
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0" id="usersTable">
                            <thead class="table-light">
                                <tr>
                                    <th>Nom</th>
                                    <th>Email</th>
                                    <th>Rôle</th>
                                    <th>Département</th>
                                    <th>Statut</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model.Users.OrderByDescending(u => u.DateCreation))
                                {
                                    var deptNom = user.DepartementId.HasValue
                                        ? departements.FirstOrDefault(d => d.Id == user.DepartementId.Value)?.Nom ?? "—"
                                        : "—";
                                    <tr>
                                        <td><strong>@user.Prenom @user.Nom</strong></td>
                                        <td><small class="text-muted">@user.Email</small></td>
                                        <td><span class="badge bg-info text-dark">@user.Role</span></td>
                                        <td><small>@deptNom</small></td>
                                        <td>
                                            @if (user.Statut)
                                            {
                                                <span class="badge bg-success-subtle text-success border border-success-subtle">Actif</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Inactif</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex gap-1">
                                                <form method="post" asp-page-handler="ToggleStatus">
                                                    <input type="hidden" name="userId" value="@user.Id">
                                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="Activer/Désactiver">
                                                        <i class="bi bi-arrow-repeat"></i>
                                                    </button>
                                                </form>
                                                <form method="post" asp-page-handler="Delete"
                                                      onsubmit="return confirm('Supprimer @user.Prenom @user.Nom ?')">
                                                    <input type="hidden" name="userId" value="@user.Id">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    // Afficher/cacher le champ département selon le rôle sélectionné
    function toggleDeptField() {
        const roleSelect = document.getElementById('roleSelect');
        const selectedText = roleSelect.options[roleSelect.selectedIndex]?.text ?? '';
        const deptField = document.getElementById('deptField');
        const deptSelect = document.getElementById('deptSelect');

        if (selectedText === 'Encadrant') {
            deptField.classList.remove('d-none');
            deptSelect.required = true;
        } else {
            deptField.classList.add('d-none');
            deptSelect.required = false;
            deptSelect.value = '';
        }
    }

    // Recherche en temps réel dans la table
    function filtrerUsers() {
        const val = document.getElementById('searchUser').value.toLowerCase();
        document.querySelectorAll('#usersTable tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(val) ? '' : 'none';
        });
    }
</script>
}
