@page
@model GestionDesStagiaires.Web.Pages.Account.LogoutModel

@{
    ViewData["Title"] = "Déconnexion";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body text-center p-5">
                    <i class="bi bi-box-arrow-right display-1 text-primary mb-3"></i>
                    <h2 class="mb-3">Déconnexion en cours...</h2>
                    <p class="text-muted">Vous êtes en train d'être déconnecté. Redirection en cours...</p>
                    <div class="spinner-border mt-3" role="status">
                        <span class="visually-hidden">Chargement...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Redirection automatique après un court délai
    setTimeout(function() {
        window.location.href = '/';
    }, 1500);
</script>
