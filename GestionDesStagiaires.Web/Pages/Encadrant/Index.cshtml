@page
@model GestionDesStagiaires.Web.Pages.Encadrant.IndexModel

@{
    ViewData["Title"] = "Gestion des Candidatures";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>
                <i class="bi bi-file-earmark-check"></i> Gestion des Candidatures
            </h1>
            <p class="text-muted">Analysez et gérez les candidatures soumises</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Filtres et Recherche -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-6">
                    <label for="searchTerm" class="form-label">Rechercher par nom du stagiaire</label>
                    <input type="text" class="form-control" id="searchTerm" name="searchTerm" 
                           placeholder="Nom ou prénom..." value="@Model.SearchTerm">
                </div>
                <div class="col-md-4">
                    <label for="filterStatus" class="form-label">Filtrer par statut</label>
                    <select class="form-select" id="filterStatus" name="filterStatus">
                        @{
                            var statuses = new[] { new { Value = "", Label = "-- Tous les statuts --" },
                                                   new { Value = "EnAttente", Label = "En attente" },
                                                   new { Value = "Acceptee", Label = "Acceptée" },
                                                   new { Value = "Refusee", Label = "Refusée" } };
                        }
                        @foreach (var status in statuses)
                        {
                            if (Model.FilterStatus == status.Value)
                            {
                                <option value="@status.Value" selected>@status.Label</option>
                            }
                            else
                            {
                                <option value="@status.Value">@status.Label</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel"></i> Filtrer
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Candidatures.Any())
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i> Aucune candidature trouvée.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Stagiaire</th>
                        <th>Email</th>
                        <th>Département</th>
                        <th>Spécialité</th>
                        <th>Niveau</th>
                        <th>Statut</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var candidature in Model.Candidatures)
                    {
                        var userInfo = Model.StagiairesInfo.ContainsKey(candidature.StagiaireId)
                            ? Model.StagiairesInfo[candidature.StagiaireId]
                            : null;

                        var fullName = userInfo?.FullName ?? $"ID: {candidature.StagiaireId}";
                        var email = userInfo?.Email ?? "-";

                        var statusBadge = candidature.Statut switch
                        {
                            "EnAttente" => "bg-warning",
                            "Acceptee" => "bg-success",
                            "Refusee" => "bg-danger",
                            _ => "bg-secondary"
                        };

                        var statusLabel = candidature.Statut switch
                        {
                            "EnAttente" => "En attente",
                            "Acceptee" => "Acceptée",
                            "Refusee" => "Refusée",
                            _ => candidature.Statut
                        };

                        var niveauLabel = candidature.NiveauEtude.ToString() switch
                        {
                            "Bac" => "Bac",
                            "BacPlus2" => "Bac +2",
                            "BacPlus3" => "Bac +3",
                            "BacPlus4" => "Bac +4",
                            "Ingenieur" => "Ing",
                            "Master" => "Master",
                            "Doctorat" => "Doc",
                            "Autre" => "Autre",
                            _ => candidature.NiveauEtude.ToString()
                        };

                        <tr>
                            <td>
                                <strong>@fullName</strong>
                            </td>
                            <td>
                                <small>@email</small>
                            </td>
                            <td>@candidature.DepartementNom</td>
                            <td>@candidature.SpecialiteNom</td>
                            <td>
                                <span class="badge bg-info">@niveauLabel</span>
                            </td>
                            <td>
                                <span class="badge @statusBadge">@statusLabel</span>
                            </td>
                            <td>@candidature.DateCreation.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (candidature.Statut == "EnAttente")
                                {
                                    <a href="/encadrant/details/@candidature.Id" class="btn btn-sm btn-outline-primary" title="Consulter">
                                        <i class="bi bi-eye"></i> Consulter
                                    </a>
                                }
                                else
                                {
                                    <a href="/encadrant/details/@candidature.Id" class="btn btn-sm btn-outline-secondary" title="Détails">
                                        <i class="bi bi-eye"></i> Détails
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                <i class="bi bi-info-circle"></i>
                Total: <strong>@Model.Candidatures.Count</strong> candidature(s) | 
                En attente: <strong>@Model.Candidatures.Count(c => c.Statut == "EnAttente")</strong> | 
                Acceptées: <strong>@Model.Candidatures.Count(c => c.Statut == "Acceptee")</strong> | 
                Refusées: <strong>@Model.Candidatures.Count(c => c.Statut == "Refusee")</strong>
            </p>
        </div>
    }
</div>
