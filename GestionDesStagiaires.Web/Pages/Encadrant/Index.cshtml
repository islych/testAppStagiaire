@page
@model GestionDesStagiaires.Web.Pages.Encadrant.IndexModel
@{
    ViewData["Title"] = "Candidatures reçues";
    var enAttente  = Model.Candidatures.Where(c => c.Statut == "EnAttente").ToList();
    var traitees   = Model.Candidatures.Where(c => c.Statut != "EnAttente").ToList();
}

<div class="container-fluid py-4" style="max-width:1100px">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="mb-0"><i class="bi bi-file-earmark-check text-primary"></i> Candidatures reçues</h2>
            <small class="text-muted">Uniquement les candidatures de votre département</small>
        </div>
        <div class="d-flex gap-2">
            <span class="badge bg-warning text-dark fs-6">@enAttente.Count en attente</span>
            <span class="badge bg-secondary fs-6">@traitees.Count traitées</span>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <!-- Barre de recherche -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-6">
                    <input type="text" class="form-control form-control-sm" name="searchTerm"
                           placeholder="Rechercher par nom du stagiaire…" value="@Model.SearchTerm">
                </div>
                <div class="col-md-4">
                    <select class="form-select form-select-sm" name="filterStatus">
                        <option value="">Tous les statuts</option>
                        <option value="EnAttente" selected="@(Model.FilterStatus=="EnAttente")">En attente</option>
                        <option value="Acceptee" selected="@(Model.FilterStatus=="Acceptee")">Acceptée</option>
                        <option value="Refusee" selected="@(Model.FilterStatus=="Refusee")">Refusée</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-sm btn-primary w-100">Filtrer</button>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Candidatures.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1"></i>
            <p class="mt-2">Aucune candidature trouvée.</p>
        </div>
    }
    else
    {
        <!-- En attente — section principale -->
        @if (enAttente.Any())
        {
            <h6 class="text-uppercase text-muted small mb-2 mt-3">
                <i class="bi bi-clock text-warning"></i> À traiter
            </h6>
            <div class="row row-cols-1 row-cols-md-2 g-3 mb-4">
                @foreach (var c in enAttente)
                {
                    var info = Model.StagiairesInfo.ContainsKey(c.StagiaireId) ? Model.StagiairesInfo[c.StagiaireId] : null;
                    <div class="col">
                        <div class="card border-warning border-start border-3 shadow-sm h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1">@(info?.FullName ?? $"Stagiaire #{c.StagiaireId}")</h6>
                                        <small class="text-muted">@(info?.Email ?? "")</small>
                                    </div>
                                    <span class="badge bg-warning text-dark">En attente</span>
                                </div>
                                <hr class="my-2">
                                <div class="row g-1 small text-muted">
                                    <div class="col-6"><i class="bi bi-building"></i> @(c.DepartementNom ?? "—")</div>
                                    <div class="col-6"><i class="bi bi-diagram-3"></i> @(c.SpecialiteNom ?? "—")</div>
                                    <div class="col-6"><i class="bi bi-calendar"></i> @c.DateCreation.ToString("dd/MM/yyyy")</div>
                                    <div class="col-6"><i class="bi bi-hourglass"></i> @c.DureeStageMois mois</div>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent border-top-0 pt-0">
                                <a href="/encadrant/details/@c.Id" class="btn btn-sm btn-primary w-100">
                                    <i class="bi bi-eye"></i> Voir et décider
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Traitées -->
        @if (traitees.Any())
        {
            <h6 class="text-uppercase text-muted small mb-2 mt-3">
                <i class="bi bi-check2-all text-secondary"></i> Traitées
            </h6>
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Stagiaire</th>
                            <th>Département</th>
                            <th>Statut</th>
                            <th>Date décision</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in traitees)
                        {
                            var info = Model.StagiairesInfo.ContainsKey(c.StagiaireId) ? Model.StagiairesInfo[c.StagiaireId] : null;
                            var badge = c.Statut == "Acceptee" ? "bg-success" : "bg-danger";
                            var label = c.Statut == "Acceptee" ? "Acceptée" : "Refusée";
                            <tr>
                                <td>
                                    <strong>@(info?.FullName ?? $"#{c.StagiaireId}")</strong>
                                    <div><small class="text-muted">@(info?.Email ?? "")</small></div>
                                </td>
                                <td><small>@(c.DepartementNom ?? "—")</small></td>
                                <td><span class="badge @badge">@label</span></td>
                                <td><small>@(c.DateDecision?.ToString("dd/MM/yyyy") ?? "—")</small></td>
                                <td>
                                    <a href="/encadrant/details/@c.Id" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>
