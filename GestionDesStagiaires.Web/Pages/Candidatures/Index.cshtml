@page
@model GestionDesStagiaires.Web.Pages.Candidatures.IndexModel
@{
    ViewData["Title"] = "Mes Candidatures";
}

<div class="container py-4" style="max-width:900px">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="mb-0"><i class="bi bi-file-earmark text-primary"></i> Mes Candidatures</h2>
        <a href="/candidatures/create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle"></i> Nouvelle candidature
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Candidatures.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body text-muted">
                <i class="bi bi-inbox fs-1"></i>
                <p class="mt-3 mb-1">Vous n'avez pas encore de candidature.</p>
                <a href="/candidatures/create" class="btn btn-outline-primary btn-sm mt-2">
                    <i class="bi bi-plus-circle"></i> Déposer une candidature
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row row-cols-1 g-3">
            @foreach (var c in Model.Candidatures)
            {
                string badgeClass, label, icon, borderClass;

                if (c.Statut == "EnAttente") {
                    badgeClass = "bg-warning text-dark"; label = "En attente"; icon = "bi-clock"; borderClass = "border-warning";
                } else if (c.Statut == "Acceptee") {
                    badgeClass = "bg-success"; label = "Acceptée"; icon = "bi-check-circle-fill"; borderClass = "border-success";
                } else if (c.Statut == "Refusee") {
                    badgeClass = "bg-danger"; label = "Refusée"; icon = "bi-x-circle-fill"; borderClass = "border-danger";
                } else {
                    badgeClass = "bg-secondary"; label = c.Statut; icon = "bi-question-circle"; borderClass = "border-secondary";
                }
                <div class="col">
                    <div class="card border-start border-3 @borderClass shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                <div>
                                    <h6 class="mb-1">
                                        @(c.DepartementNom ?? $"Département #{c.DepartementId}")
                                        <span class="text-muted fw-normal">/ @(c.SpecialiteNom ?? $"Spécialité #{c.SpecialiteId}")</span>
                                    </h6>
                                    <small class="text-muted">
                                        <i class="bi bi-building"></i> @c.Ecole &nbsp;·&nbsp;
                                        <i class="bi bi-mortarboard"></i> @c.NiveauEtude &nbsp;·&nbsp;
                                        <i class="bi bi-hourglass"></i> @c.DureeStageMois mois
                                    </small>
                                </div>
                                <span class="badge @badgeClass">
                                    <i class="bi @icon"></i> @label
                                </span>
                            </div>

                            @if (c.Statut == "Acceptee")
                            {
                                <div class="alert alert-success py-2 px-3 mt-3 mb-0 small">
                                    <i class="bi bi-envelope-check"></i>
                                    Candidature acceptée ! Rendez-vous dans <a href="/candidatures/acceptee" class="alert-link">Ma candidature acceptée</a> pour envoyer vos documents.
                                </div>
                            }
                            @if (c.Statut == "Refusee" && !string.IsNullOrEmpty(c.Commentaire))
                            {
                                <div class="alert alert-danger py-2 px-3 mt-3 mb-0 small">
                                    <i class="bi bi-chat-left-text"></i> <strong>Motif :</strong> @c.Commentaire
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-transparent border-top d-flex gap-2 justify-content-end">
                            <small class="text-muted me-auto align-self-center">
                                Déposée le @c.DateCreation.ToString("dd/MM/yyyy")
                            </small>
                            <a href="/candidatures/suivi/@c.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-graph-up"></i> Suivi
                            </a>
                            <a href="/candidatures/details/@c.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i> Détails
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
