@page "{id:guid}"
@model GestionDesStagiaires.Web.Pages.Candidatures.DetailsModel

@{
    ViewData["Title"] = "Détails de Candidature";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-8 mx-auto">
            <a href="/candidatures" class="btn btn-outline-secondary mb-3">
                <i class="bi bi-arrow-left"></i> Retour
            </a>
            <h1>
                <i class="bi bi-file-earmark"></i> Détails de Candidature
            </h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8 mx-auto">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (Model.Candidature != null)
            {
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h6 class="text-muted">Statut</h6>
                                <span class="badge bg-primary fs-6">@Model.Candidature.Statut</span>
                            </div>
                            <div class="col-md-6 text-md-end">
                                <h6 class="text-muted">Date de création</h6>
                                <p>@Model.Candidature.DateCreation.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                        </div>

                        <hr>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <h6 class="text-muted">Département</h6>
                                <p>@Model.Candidature.DepartementId</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <h6 class="text-muted">Spécialité</h6>
                                <p>@Model.Candidature.SpecialiteId</p>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <h6 class="text-muted">Fichier CV</h6>
                                <p>@Model.Candidature.CvFileName</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <h6 class="text-muted">Chemin</h6>
                                <p><code>@Model.Candidature.CvPath</code></p>
                            </div>
                        </div>

                        @if (Model.Candidature.DateDecision.HasValue)
                        {
                            <hr>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <h6 class="text-muted">Date de décision</h6>
                                    <p>@Model.Candidature.DateDecision.Value.ToString("dd/MM/yyyy HH:mm")</p>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.Candidature.Commentaire))
                        {
                            <hr>
                            <div class="alert alert-info" role="alert">
                                <h6 class="alert-heading">Commentaire</h6>
                                <p class="mb-0">@Model.Candidature.Commentaire</p>
                            </div>
                        }
                    </div>
                </div>

                <div class="mt-3">
                    <a href="/candidatures/suivi/@Model.Candidature.Id" class="btn btn-info">
                        <i class="bi bi-graph-up"></i> Voir le suivi
                    </a>
                </div>
            }
        </div>
    </div>
</div>
