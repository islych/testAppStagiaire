@page "{id:guid}"
@model GestionDesStagiaires.Web.Pages.Candidatures.SuiviModel

@{
    ViewData["Title"] = "Suivi de Candidature";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-8 mx-auto">
            <a href="/candidatures" class="btn btn-outline-secondary mb-3">
                <i class="bi bi-arrow-left"></i> Retour
            </a>
            <h1>
                <i class="bi bi-graph-up"></i> Suivi de Candidature
            </h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8 mx-auto">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (Model.Suivi != null)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Statut Actuel</h5>
                    </div>
                    <div class="card-body">
                        <div class="text-center mb-4">
                            <span class="badge @Model.Suivi.StatutBadgeClass fs-5">@Model.Suivi.StatutLabel</span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <h6 class="text-muted">Créée le</h6>
                                <p class="lead">@Model.Suivi.DateCreation.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>

                            @if (Model.Suivi.DateDecision.HasValue)
                            {
                                <div class="col-md-6 mb-3">
                                    <h6 class="text-muted">Décision le</h6>
                                    <p class="lead">@Model.Suivi.DateDecision.Value.ToString("dd/MM/yyyy HH:mm")</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Suivi.Commentaire))
                {
                    <div class="card shadow-sm mb-4 border-info">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0">Commentaire</h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text">@Model.Suivi.Commentaire</p>
                        </div>
                    </div>
                }

                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Historique</h5>
                    </div>
                    <div class="card-body">
                        <div class="timeline">
                            @{
                                var s = Model.Suivi.Statut;
                                bool depasse(string step) => step switch {
                                    "created"    => true,
                                    "encadrant"  => s != "EnAttente",
                                    "direction"  => s == "TransmiseADirection" || s == "Acceptee" || s == "Refusee",
                                    "acceptee"   => s == "Acceptee" || s == "Refusee",
                                    _ => false
                                };
                            }
                            <div class="timeline-item mb-3">
                                <div class="timeline-marker bg-success">
                                    <i class="bi bi-file-earmark-plus text-white"></i>
                                </div>
                                <div>
                                    <h6>Candidature déposée</h6>
                                    <small class="text-muted">@Model.Suivi.DateCreation.ToString("dd/MM/yyyy à HH:mm")</small>
                                </div>
                            </div>

                            <div class="timeline-item mb-3">
                                <div class="timeline-marker @(depasse("encadrant") ? "bg-success" : "bg-light border")">
                                    <i class="bi bi-person-check @(depasse("encadrant") ? "text-white" : "text-muted")"></i>
                                </div>
                                <div>
                                    <h6 class="@(depasse("encadrant") ? "" : "text-muted")">Examinée par l'encadrant</h6>
                                    @if (depasse("encadrant"))
                                    {
                                        <small class="text-muted">Transmise à la Direction</small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">En attente</small>
                                    }
                                </div>
                            </div>

                            <div class="timeline-item mb-3">
                                <div class="timeline-marker @(depasse("direction") ? "bg-success" : "bg-light border")">
                                    <i class="bi bi-star @(depasse("direction") ? "text-white" : "text-muted")"></i>
                                </div>
                                <div>
                                    <h6 class="@(depasse("direction") ? "" : "text-muted")">Accord de stage — Direction</h6>
                                    @if (s == "TransmiseADirection")
                                    {
                                        <small class="text-warning">En cours d'examen</small>
                                    }
                                    else if (depasse("direction"))
                                    {
                                        <small class="text-muted">Validé</small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">En attente</small>
                                    }
                                </div>
                            </div>

                            <div class="timeline-item">
                                <div class="timeline-marker @(s == "Acceptee" ? "bg-success" : s == "Refusee" ? "bg-danger" : "bg-light border")">
                                    <i class="bi @(s == "Acceptee" ? "bi-check2-circle" : s == "Refusee" ? "bi-x-circle" : "bi-hourglass") @(s == "Acceptee" || s == "Refusee" ? "text-white" : "text-muted")"></i>
                                </div>
                                <div>
                                    <h6 class="@(s == "Acceptee" || s == "Refusee" ? "" : "text-muted")">Décision finale</h6>
                                    @if (s == "Acceptee")
                                    {
                                        <small class="text-success">Candidature acceptée — déposez vos documents</small>
                                    }
                                    else if (s == "Refusee")
                                    {
                                        <small class="text-danger">Candidature refusée</small>
                                        @if (!string.IsNullOrEmpty(Model.Suivi.Commentaire))
                                        {
                                            <p class="text-muted small mt-1">@Model.Suivi.Commentaire</p>
                                        }
                                    }
                                    else
                                    {
                                        <small class="text-muted">En attente</small>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @if (s == "Acceptee")
                {
                    <div class="alert alert-success mt-3">
                        <i class="bi bi-check-circle"></i> Votre candidature est acceptée.
                        <a href="/documents" class="btn btn-success btn-sm ms-2">
                            <i class="bi bi-upload"></i> Déposer mes documents
                        </a>
                    </div>
                }

                <div class="mt-3">
                    <a href="/candidatures/details/@Model.Suivi.Id" class="btn btn-outline-primary">
                        <i class="bi bi-eye"></i> Voir les détails complets
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .timeline-marker {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 10px;
    }

    .timeline-item {
        display: flex;
        gap: 15px;
        margin-left: 20px;
        padding-left: 20px;
        border-left: 3px solid #dee2e6;
    }

    .timeline-item:last-child {
        border-left: none;
    }
</style>
